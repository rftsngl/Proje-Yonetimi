# Lütfen .env.example olan dosya adını .env olarak değiştirin. 

# Backend API / MySQL
PORT="4000"
MYSQL_HOST="127.0.0.1"
MYSQL_PORT="3306"
MYSQL_USER="root"
MYSQL_PASSWORD="YOUR_MYSQL_PASSWORD"
MYSQL_DATABASE="proje_yonetimi_app"
VITE_API_PROXY_TARGET="http://localhost:4001"

# OpenRouter web siyesi üzerinden bir api anahtarı alıp buraya yapıştırın.
OPENROUTER_API_KEY="" 
